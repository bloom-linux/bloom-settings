#!/usr/bin/env python3
"""Bloom Settings — full system control panel"""

import gi
gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk, GLib
import sys, os

# Run natively on Wayland
os.environ.setdefault("GDK_BACKEND", "wayland")

# Add lib directory to path for page modules
sys.path.insert(0, "/usr/local/lib/bloom-settings")

import common as _common
from common import CSS, _reload_app_css

from page_personalization import AppearancePage, DisplayPage, SoundPage
from page_users import UsersPage
from page_connectivity import NetworkPage, BluetoothPage
from page_applications import DefaultAppsPage
from page_system import KernelsPage, DriversPage, LocalePage, PowerPage, NotificationsPage, UpdatesPage, AboutPage
from page_input import KeyboardPage, MouseTouchpadPage, AccessibilityPage
from page_startup import StartupSessionPage, PrivacySecurityPage
from page_files import FilesPage

# Each entry: (icon, name, factory) for pages, (None, name, None) for category headers
PAGES = [
    (None, "PERSONALIZATION", None),
    ("󰸉", "Appearance",         lambda w: AppearancePage(w)),
    ("󰍹", "Display",            lambda w: DisplayPage(w)),
    ("󰕾", "Sound",              lambda w: SoundPage(w)),
    (None, "USERS", None),
    ("󰀖", "Users",              lambda w: UsersPage(w)),
    (None, "CONNECTIVITY", None),
    ("󰤨", "Network",            lambda w: NetworkPage(w)),
    ("󰂯", "Bluetooth",          lambda w: BluetoothPage(w)),
    (None, "INPUT DEVICES", None),
    ("󰌌", "Keyboard",           lambda w: KeyboardPage(w)),
    ("󰍽", "Mouse & Touchpad",   lambda w: MouseTouchpadPage(w)),
    ("󰈙", "Accessibility",      lambda w: AccessibilityPage(w)),
    (None, "APPLICATIONS", None),
    ("", "Default Apps",       lambda w: DefaultAppsPage(w)),
    ("󰒲", "Startup & Session",  lambda w: StartupSessionPage(w)),
    (None, "SYSTEM", None),
    ("", "Kernels",            lambda w: KernelsPage(w)),
    ("󰍛", "Drivers",            lambda w: DriversPage(w)),
    ("󰗔", "Locale & Time",      lambda w: LocalePage(w)),
    ("", "Power",              lambda w: PowerPage(w)),
    ("󰂚", "Notifications",      lambda w: NotificationsPage(w)),
    ("󰒡", "Privacy & Security", lambda w: PrivacySecurityPage(w)),
    ("󰏖", "Updates",            lambda w: UpdatesPage(w)),
    ("", "About",              lambda w: AboutPage()),
    (None, "TOOLS", None),
    ("󰍉", "File Search",       lambda w: FilesPage(w)),
]


def on_activate(app):
    global _CSS_PROVIDER
    win = Gtk.ApplicationWindow(application=app)
    win.set_title("Bloom Settings")
    win.set_default_size(1060, 720)
    win.set_size_request(640, 480)
    win.set_resizable(True)

    _CSS_PROVIDER = Gtk.CssProvider()
    try:
        _CSS_PROVIDER.load_from_string(CSS)
    except AttributeError:
        _CSS_PROVIDER.load_from_data(CSS.encode())
    Gtk.StyleContext.add_provider_for_display(
        Gdk.Display.get_default(), _CSS_PROVIDER,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )
    # Share provider with common module so _reload_app_css works
    _common._CSS_PROVIDER = _CSS_PROVIDER

    root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)

    # ── Sidebar ───────────────────────────────────────────────────────────────
    sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    sidebar.add_css_class("sidebar")

    logo = Gtk.Label(label="⚙  Settings")
    logo.add_css_class("sidebar-title"); logo.set_xalign(0)
    sidebar.append(logo)

    # Search box
    search_entry = Gtk.SearchEntry()
    search_entry.set_placeholder_text("Search…")
    search_entry.set_margin_start(10); search_entry.set_margin_end(10)
    search_entry.set_margin_bottom(6)
    sidebar.append(search_entry)

    nav_scroll = Gtk.ScrolledWindow()
    nav_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    nav_scroll.set_vexpand(True)
    nav_inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    nav_scroll.set_child(nav_inner)
    sidebar.append(nav_scroll)

    # ── Stack ─────────────────────────────────────────────────────────────────
    stack = Gtk.Stack()
    stack.set_hexpand(True); stack.set_vexpand(True)
    stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
    stack.set_transition_duration(100)

    btns = []

    def switch(btn, name):
        for b in btns:
            b.remove_css_class("active")
        btn.add_css_class("active")
        stack.set_visible_child_name(name)

    # Pages that manage their own internal scroll (need no outer wrapper)
    NO_SCROLL_PAGES = {"Appearance"}

    first_page = None
    for icon, name, factory in PAGES:
        if factory is None:
            cat = Gtk.Label(label=name); cat.add_css_class("sidebar-cat"); cat.set_xalign(0)
            nav_inner.append(cat)
            continue

        page_holder = Gtk.Box()
        page_holder.set_hexpand(True); page_holder.set_vexpand(True)

        if name in NO_SCROLL_PAGES:
            stack.add_named(page_holder, name)
        else:
            scroll = Gtk.ScrolledWindow()
            scroll.set_hexpand(True); scroll.set_vexpand(True)
            scroll.set_child(page_holder)
            stack.add_named(scroll, name)

        _loaded = [False]
        def make_loader(f, holder, loaded, win_ref=win):
            def loader():
                if not loaded[0]:
                    loaded[0] = True
                    page = f(win_ref)
                    holder.append(page)
            return loader

        loader = make_loader(factory, page_holder, _loaded)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        row.set_margin_start(4)
        il = Gtk.Label(label=icon); il.set_size_request(22, -1); row.append(il)
        row.append(Gtk.Label(label=name))

        btn = Gtk.Button(); btn.set_child(row); btn.add_css_class("nav-btn")
        btn.connect("clicked", lambda b, n=name, l=loader: (l(), switch(b, n)))
        btns.append(btn)
        nav_inner.append(btn)

        if first_page is None:
            first_page = (btn, name, loader)

    # Wire up sidebar search — filters nav buttons and category labels
    _all_nav_items = list(nav_inner)  # snapshot after population

    def _on_sidebar_search(entry):
        q = entry.get_text().lower().strip()
        if not q:
            for child in _all_nav_items:
                child.set_visible(True)
            return
        # Show only buttons whose label contains the query; hide category labels
        # that have no visible buttons below them
        visible_names = set()
        for b in btns:
            row_child = b.get_child()
            label_text = ""
            if row_child:
                c = row_child.get_first_child()
                while c:
                    if hasattr(c, "get_label"):
                        label_text += " " + (c.get_label() or "")
                    c = c.get_next_sibling()
            if q in label_text.lower():
                b.set_visible(True)
                visible_names.add(b)
            else:
                b.set_visible(False)

        # Show/hide category labels based on whether any following btn is visible
        children = list(_all_nav_items)
        for i, child in enumerate(children):
            if child in btns:
                continue  # already handled
            # It's a category label — show if any subsequent btn is visible
            has_visible = any(
                c for c in children[i+1:]
                if c in btns and c.get_visible()
            )
            child.set_visible(has_visible)

    search_entry.connect("search-changed", _on_sidebar_search)

    if first_page and btns:
        btn, name, loader = first_page
        loader()
        btn.add_css_class("active")
        stack.set_visible_child_name(name)

    root.append(sidebar)
    root.append(stack)
    win.set_child(root)
    win.present()


app = Gtk.Application(application_id="bloom.settings")
app.connect("activate", on_activate)
sys.exit(app.run(sys.argv))
